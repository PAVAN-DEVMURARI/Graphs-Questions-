#include<bits/stdc++.h>

string cycleDetection(vector<vector<int>>& edges, int n, int m)
{
    // Size n+1 rakho (1-indexed ke liye)
    vector<vector<int>> adj(n + 1);           // ? Fix 1

    for(int i = 0; i < m; i++)
    {
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    vector<int> visi(n + 1, 0);               // ? Fix 2

    // 1 se n tak loop chalao
    for(int start = 1; start <= n; start++)    // ? Fix 3
    {
        if(visi[start]) continue;

        queue<pair<int,int>> q;
        visi[start] = 1;
        q.push({start, -1});

        while(!q.empty())
        {
            int node = q.front().first;
            int parent = q.front().second;
            q.pop();

            for(auto it : adj[node])
            {
                if(!visi[it])
                {
                    visi[it] = 1;
                    q.push({it, node});
                }
                else if(parent != it)
                {
                    return "Yes";
                }
            }
        }
    }

    return "No";
}
